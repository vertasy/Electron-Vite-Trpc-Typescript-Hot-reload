{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist-electron",

    // "strict": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    // "allowSyntheticDefaultImports": true,
    // "resolveJsonModule": true,

    "types": ["node", "./types"]
  },

  "include": [
    "src/electron/**/*",
    "src/backend/**/*",
    "src/shared/**/*",
    "globals.d.ts"
  ]
}
