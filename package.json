{
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:ui": "vite",
    "watch:electron": "tsc -w -p tsconfig.node.json",
    "dev:electron": "wait-on dist-electron/electron/main.js && electron dist-electron/electron/main.js",
    "dev": "concurrently \"npm run dev:ui\" \"npm run watch:electron\" \"npm run dev:electron\"",
    "build:ui": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:ui && npm run build:electron",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tailwindcss/vite": "^4.3.1",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electron": "^42.5.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.yourcompany.yourapp",
    "productName": "Thootie",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
