{
  "name": "thootie",
  "version": "1.0.0",
  "description": "A modern Electron starter template built with:",
  "homepage": "https://github.com/vertasy/Electron-Vite-Trpc-Typescript-Hot-reload#readme",
  "bugs": {
    "url": "https://github.com/vertasy/Electron-Vite-Trpc-Typescript-Hot-reload/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vertasy/Electron-Vite-Trpc-Typescript-Hot-reload.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:ui": "vite",
    "watch:electron": "tsc -w -p tsconfig.node.json",
    "dev:electron": "wait-on dist-electron/electron/main.js && electron dist-electron/electron/main.js",
    "dev": "concurrently \"npm run dev:ui\" \"npm run watch:electron\" \"npm run dev:electron\"",
    "build:ui": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:ui && npm run build:electron",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tailwindcss/vite": "^4.3.1",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "discord.js": "^14.26.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.4",
    "input-otp": "^1.4.2",
    "install": "^0.13.0",
    "lucide-react": "^1.21.0",
    "mime-types": "^3.0.2",
    "motion": "^12.42.0",
    "npm": "^11.17.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "uuid": "^14.0.1",
    "vite": "^8.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.9.2",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.yourcompany.yourapp",
    "productName": "Thootie",
    "asar": false,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/migrations",
        "to": "migrations"
      },
      {
        "from": "resources/face",
        "to": "face"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
