{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "noEmit": true,

    "types": ["vite/client", "./types"]
  },

  "include": ["src/ui/**/*", "globals.d.ts"]
}
